# Copy to `.env.supabase.local` (git-ignored) and fill these in locally.
# Keep service role / DB passwords out of app code and out of git.

# Supabase project ref (from your project URL)
SUPABASE_PROJECT_REF=lvapccwqypcvhijmevbh

# Supabase CLI personal access token (Dashboard -> Account -> Access Tokens)
SUPABASE_ACCESS_TOKEN=

# Project DB password (Dashboard -> Project Settings -> Database)
SUPABASE_DB_PASSWORD=

# Optional direct SQL URL (psql). If omitted, the helper script will build a secure
# connection using SUPABASE_PROJECT_REF + SUPABASE_DB_PASSWORD.
# If you do use a URL, make sure special characters in the password are URL-encoded.
# Example:
# postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_URL=
